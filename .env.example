# Band 平台连接(SDK 默认就指向生产环境,一般不用改)
THENVOI_REST_URL=https://app.band.ai/
THENVOI_WS_URL=wss://app.band.ai/api/v1/socket/websocket

# LLM 提供商密钥(只填用到的;M0 只需要 ANTHROPIC_API_KEY)
ANTHROPIC_API_KEY=
AIMLAPI_API_KEY=
AIMLAPI_BASE_URL=https://api.aimlapi.com/v1
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1

# 真实数据(M5):Finnhub(finnhub.io 免费注册拿 key)
FINNHUB_API_KEY=
DATA_SOURCE=finnhub          # finnhub=真实数据;stub=离线假数据回退

# 角色 → 模型路由(换模型改这里,不改代码)
BULL_PROVIDER=anthropic
BULL_MODEL=claude-sonnet-4-6
BEAR_PROVIDER=featherless
BEAR_MODEL=                  # 必须与 Bull 不同模型家族
CHAIR_PROVIDER=anthropic
CHAIR_MODEL=claude-sonnet-4-6
RISK_PROVIDER=anthropic
RISK_MODEL=claude-haiku-4-5-20251001
DATA_PROVIDER=aimlapi
DATA_MODEL=
# M0 管道探针(echo)用的模型
ECHO_MODEL=claude-haiku-4-5-20251001

# 运行参数
COUNTERPOINT_ROOM=Counterpoint Desk
TICKER=AAPL
DEBATE_ROUNDS=1

# 产出语言:zh=中文(默认),en=英文。决定备忘录/辩论/证据包/工具描述的语言。
# 换语言改这里、不改代码,一次只能一种语言(同一 Band 账号一套 agent)。
# Web UI 语言独立于此(界面右上角 EN/中 切换),互不影响。
OUTPUT_LANG=zh
